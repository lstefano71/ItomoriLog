<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ItomoriLog.UI.ViewModels"
             xmlns:views="using:ItomoriLog.UI.Views"
             x:Class="ItomoriLog.UI.Views.SessionShellView"
             x:DataType="vm:SessionShellViewModel">

  <DockPanel>
    <Grid DockPanel.Dock="Top"
          IsVisible="{Binding CrashRecovery, Converter={x:Static ObjectConverters.IsNotNull}}">
      <views:CrashRecoveryBannerView DataContext="{Binding CrashRecovery}" />
    </Grid>

    <Border DockPanel.Dock="Top" Background="{StaticResource Itomori.Panel}" Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">
        <Grid IsVisible="{Binding !IsEditingHeader}">
          <StackPanel Orientation="Horizontal" Spacing="16">
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource Itomori.Foreground}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Description}" FontSize="13"
                       Foreground="{StaticResource Itomori.SubtleForeground}" VerticalAlignment="Center" />
            <Border Background="#2A2F3A" CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                    IsVisible="{Binding DefaultTimezone, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="{Binding DefaultTimezone}" FontSize="11"
                         Foreground="{StaticResource Brush.NeonCyan}" />
            </Border>
          </StackPanel>
        </Grid>

        <Grid IsVisible="{Binding IsEditingHeader}">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBox Text="{Binding EditableTitle}" Width="260" />
            <TextBox Text="{Binding EditableDescription}" Width="300" />
            <TextBox Text="{Binding EditableTimezone}" Width="220" />
            <Button Content="Save" Command="{Binding SaveHeaderCommand}" />
            <Button Content="Cancel" Command="{Binding CancelHeaderEditCommand}" />
          </StackPanel>
        </Grid>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="{Binding StagingPaneToggleText}"
                  Command="{Binding ToggleStagingPaneCommand}"
                  Background="Transparent" BorderThickness="0" />
          <Button Content="Edit" Command="{Binding BeginHeaderEditCommand}"
                  Background="Transparent" BorderThickness="0"
                  IsVisible="{Binding !IsEditingHeader}" />
          <Button Content="✕ Close" Command="{Binding CloseSessionCommand}"
                  Background="Transparent" BorderThickness="0" />
        </StackPanel>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource Itomori.Panel}" Padding="16,6">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*">
        <Border Background="#2A2F3A" CornerRadius="3" Padding="8,2" Margin="0,0,12,0">
          <TextBlock Text="{Binding RecordCount, StringFormat='{}{0:N0} records'}" FontSize="12"
                     Foreground="{StaticResource Brush.NeonCyan}" />
        </Border>
        <TextBlock Grid.Column="1" Text="{Binding DefaultTimezone}" FontSize="12"
                   Foreground="{StaticResource Itomori.SubtleForeground}" Margin="0,0,12,0"
                   VerticalAlignment="Center" />
        <Border Grid.Column="2" Background="#2A2F3A" CornerRadius="3" Padding="8,2" Margin="0,0,12,0"
                IsVisible="{Binding IsIngesting}">
          <TextBlock Text="⟳ Ingesting..." FontSize="12"
                     Foreground="{StaticResource Brush.SakuraPink}" />
        </Border>
        <TextBlock Grid.Column="3" Text="{Binding OverallThroughputDisplay}" FontSize="12"
                   Foreground="{StaticResource Brush.NeonCyan}" Margin="0,0,12,0"
                   IsVisible="{Binding IsIngesting}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="{Binding StatusText}" FontSize="12"
                   Foreground="{StaticResource Itomori.SubtleForeground}"
                   HorizontalAlignment="Right" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Panel>
      <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
              IsVisible="{Binding Timeline, Converter={x:Static ObjectConverters.IsNotNull}}">
          <views:TimelineCanvasView DataContext="{Binding Timeline}" />
        </Grid>

        <Grid Grid.Row="1"
              Grid.Column="0"
              Width="220"
              IsVisible="{Binding FacetPanel, Converter={x:Static ObjectConverters.IsNotNull}}">
          <views:FacetPanelView DataContext="{Binding FacetPanel}" />
        </Grid>

        <Grid Grid.Row="1"
              Grid.Column="1"
              IsVisible="{Binding LogsPage, Converter={x:Static ObjectConverters.IsNotNull}}">
          <SplitView IsPaneOpen="{Binding LogsPage.IsDetailOpen}"
                     DisplayMode="Inline"
                     PanePlacement="Right"
                     OpenPaneLength="420">
            <SplitView.Pane>
              <views:DetailDrawerView DataContext="{Binding LogsPage}" />
            </SplitView.Pane>
            <views:LogGridView DataContext="{Binding LogsPage}" />
          </SplitView>
        </Grid>
      </Grid>

      <Border HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Width="760"
              Background="{StaticResource Itomori.Panel}"
              BorderBrush="#2A2F3A"
              BorderThickness="1,0,0,0"
              IsVisible="{Binding IsStagingPaneOpen}">
        <Grid RowDefinitions="Auto,Auto,Auto,*">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="12,10,12,6">
            <StackPanel Spacing="2">
              <TextBlock Text="Staging queue"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource Brush.NeonCyan}" />
              <TextBlock Text="{Binding StagingSummary}"
                         FontSize="11"
                         Foreground="{StaticResource Itomori.SubtleForeground}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Hide"
                    Command="{Binding ToggleStagingPaneCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8,2" />
          </Grid>

          <StackPanel Grid.Row="1"
                      Orientation="Horizontal"
                      Spacing="6"
                      Margin="12,0,12,6">
            <Button Content="Add files"
                    Name="AddFilesButton"
                    IsEnabled="{Binding CanModifyStagedSources}"
                    Padding="10,4"
                    FontSize="12" />
            <Button Content="Add folder"
                    Name="AddFolderButton"
                    IsEnabled="{Binding CanModifyStagedSources}"
                    Padding="10,4"
                    FontSize="12" />
            <Button Content="Clear"
                    Command="{Binding ClearStagedSourcesCommand}"
                    IsEnabled="{Binding CanModifyStagedSources}"
                    Padding="10,4"
                    FontSize="12" />
            <Button Content="Start"
                    Command="{Binding StartIngestionCommand}"
                    IsEnabled="{Binding CanStartIngestion}"
                    Padding="10,4"
                    FontSize="12" />
          </StackPanel>

          <StackPanel Grid.Row="2" Spacing="3" Margin="12,0,12,6">
            <TextBlock Text="Sniffing timestamp, timezone, encoding, and structure..."
                       FontSize="11"
                       Foreground="{StaticResource Brush.NeonCyan}"
                       IsVisible="{Binding HasSniffingInProgress}" />
            <TextBlock Text="Some staged files need confirmation before ingesting."
                       FontSize="11"
                       Foreground="{StaticResource Brush.SakuraPink}"
                       IsVisible="{Binding HasPendingDetectionReview}" />
            <Grid ColumnDefinitions="Auto,Auto,Auto" IsVisible="{Binding IsIngesting}">
              <TextBlock Text="{Binding OverallProgressDisplay}" FontSize="11" Margin="0,0,10,0" />
              <TextBlock Grid.Column="1" Text="{Binding OverallThroughputDisplay}" FontSize="11" Margin="0,0,10,0" />
              <TextBlock Grid.Column="2" Text="{Binding OverallEtaDisplay, StringFormat='ETA {0}'}" FontSize="11" />
            </Grid>
          </StackPanel>

          <Grid Grid.Row="3" ColumnDefinitions="3*,2*" ColumnSpacing="10" Margin="12,0,12,12">
            <Border Background="#141922" CornerRadius="6" Padding="2">
              <ListBox ItemsSource="{Binding StagedSources}"
                       SelectedItem="{Binding SelectedStagedSource}"
                       Background="Transparent"
                       BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:StagedSourceItemViewModel">
                    <Border Padding="4,3" Margin="0,0,0,1" Background="#181C24" CornerRadius="3">
                      <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" RowSpacing="1">
                        <TextBlock Text="{Binding SourceName}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Itomori.Foreground}"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="1" Background="#2A2F3A" CornerRadius="3" Padding="4,0" Margin="4,0,3,0">
                          <TextBlock Text="{Binding ConfidenceDisplay}" FontSize="9" />
                        </Border>
                        <Border Grid.Column="2" Background="#2A2F3A" CornerRadius="3" Padding="4,0">
                          <TextBlock Text="{Binding DetectionBadge}" FontSize="9" />
                        </Border>

                        <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                                   Text="{Binding QueueSummary}"
                                   FontSize="10"
                                   Foreground="{StaticResource Itomori.SubtleForeground}"
                                   TextTrimming="CharacterEllipsis" />

                        <ProgressBar Grid.Row="2" Grid.ColumnSpan="3"
                                     Height="2"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="{Binding ProgressRatio}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <Grid Grid.Column="1">
              <Border Background="#141922"
                      CornerRadius="6"
                      Padding="10"
                      IsVisible="{Binding HasSelectedStagedSource}">
                <ScrollViewer>
                  <StackPanel DataContext="{Binding SelectedStagedSource}" Spacing="10">
                    <StackPanel Spacing="3">
                      <TextBlock Text="{Binding SourceName}"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Itomori.Foreground}" />
                      <TextBlock Text="{Binding SourcePath}"
                                 FontSize="11"
                                 Foreground="{StaticResource Itomori.SubtleForeground}"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Background="#2A2F3A" CornerRadius="3" Padding="6,2">
                        <TextBlock Text="{Binding ConfidenceDisplay}" FontSize="10" />
                      </Border>
                      <Border Background="#2A2F3A" CornerRadius="3" Padding="6,2">
                        <TextBlock Text="{Binding DetectionBadge}" FontSize="10" />
                      </Border>
                      <Border Background="#2A2F3A" CornerRadius="3" Padding="6,2">
                        <TextBlock Text="{Binding Phase}" FontSize="10" />
                      </Border>
                    </StackPanel>

                    <StackPanel Spacing="5">
                      <TextBlock Text="Detected profile"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Itomori.SubtleForeground}" />
                      <ComboBox ItemsSource="{Binding DetectionChoices}"
                                SelectedItem="{Binding SelectedDetectionChoice}"
                                DisplayMemberBinding="{Binding DisplayName}"
                                IsEnabled="{Binding CanSelectDetection}" />
                      <TextBlock Text="{Binding DetectionSummary}"
                                 TextWrapping="Wrap"
                                 FontSize="11"
                                 Foreground="{StaticResource Itomori.Foreground}" />
                      <TextBlock Text="This guess needs confirmation before ingesting."
                                 FontSize="11"
                                 Foreground="{StaticResource Brush.SakuraPink}"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding RequiresDetectionReview}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Button Content="Confirm choice"
                              Command="{Binding $parent[UserControl].DataContext.ConfirmDetectionCommand}"
                              CommandParameter="{Binding}"
                              IsVisible="{Binding RequiresDetectionReview}"
                              Padding="10,4"
                              FontSize="12" />
                      <Button Content="Re-ingest"
                              Command="{Binding $parent[UserControl].DataContext.ReingestSourceCommand}"
                              CommandParameter="{Binding}"
                              IsEnabled="{Binding CanReingest}"
                              Padding="10,4"
                              FontSize="12" />
                      <Button Content="Remove"
                              Command="{Binding $parent[UserControl].DataContext.RemoveStagedSourceCommand}"
                              CommandParameter="{Binding}"
                              IsEnabled="{Binding CanEdit}"
                              Padding="10,4"
                              FontSize="12" />
                    </StackPanel>

                    <StackPanel Spacing="5" IsVisible="{Binding HasDetectionDetails}">
                      <TextBlock Text="Details"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Itomori.SubtleForeground}" />
                      <ItemsControl ItemsSource="{Binding DetectionDetails}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:DetectionDetailViewModel">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,4">
                              <TextBlock Text="{Binding Label}"
                                         FontSize="11"
                                         Foreground="{StaticResource Itomori.SubtleForeground}"
                                         Margin="0,0,8,0" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Value}"
                                         FontSize="11"
                                         TextWrapping="Wrap"
                                         Foreground="{StaticResource Itomori.Foreground}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="5" IsVisible="{Binding HasDetectionNotes}">
                      <TextBlock Text="Detector notes"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Itomori.SubtleForeground}" />
                      <TextBlock Text="{Binding DetectionNotes}"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 Foreground="{StaticResource Itomori.Foreground}" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                      <TextBlock Text="Progress"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Itomori.SubtleForeground}" />
                      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                        <TextBlock Text="Bytes" FontSize="11" Foreground="{StaticResource Itomori.SubtleForeground}" />
                        <TextBlock Grid.Column="1" Text="{Binding ProgressDisplay}" FontSize="11" />
                        <TextBlock Grid.Row="1" Text="Rows" FontSize="11" Foreground="{StaticResource Itomori.SubtleForeground}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RecordsProcessed, StringFormat='{}{0:N0}'}" FontSize="11" />
                        <TextBlock Grid.Row="2" Text="Throughput" FontSize="11" Foreground="{StaticResource Itomori.SubtleForeground}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ThroughputDisplay}" FontSize="11" />
                        <TextBlock Grid.Row="3" Text="ETA" FontSize="11" Foreground="{StaticResource Itomori.SubtleForeground}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EtaDisplay}" FontSize="11" />
                      </Grid>
                      <TextBlock Text="{Binding Message}"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 Foreground="{StaticResource Itomori.SubtleForeground}"
                                 IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </StackPanel>
                </ScrollViewer>
              </Border>

              <Border Background="#141922"
                      CornerRadius="6"
                      Padding="10"
                      IsVisible="{Binding !HasSelectedStagedSource}">
                <TextBlock Text="Select a staged file to inspect the guessed timestamp pattern, timezone handling, encoding, and structure."
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Itomori.SubtleForeground}" />
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Panel>
  </DockPanel>

</UserControl>
