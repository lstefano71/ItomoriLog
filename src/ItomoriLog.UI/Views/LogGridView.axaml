<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ItomoriLog.UI.ViewModels"
             x:Class="ItomoriLog.UI.Views.LogGridView"
             x:DataType="vm:LogsPageViewModel">

  <Grid RowDefinitions="*">
    <DataGrid Grid.Row="0"
              Name="LogDataGrid"
              ItemsSource="{Binding CurrentPage}"
              SelectedItem="{Binding SelectedRow}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              RowHeight="22"
              ColumnHeaderHeight="24"
              HeadersVisibility="Column"
              BorderThickness="0"
              RowBackground="#141922"
              Background="{StaticResource Itomori.Background}"
              Foreground="{StaticResource Itomori.Foreground}">
      <DataGrid.Styles>
        <Style Selector="DataGridRow">
          <Setter Property="Foreground" Value="{StaticResource Itomori.Foreground}" />
          <Setter Property="MinHeight" Value="22" />
        </Style>
        <Style Selector="DataGridCell">
          <Setter Property="Foreground" Value="{StaticResource Itomori.Foreground}" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Padding" Value="8,2" />
          <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="DataGridColumnHeader">
          <Setter Property="Padding" Value="8,4" />
          <Setter Property="FontSize" Value="11" />
        </Style>
      </DataGrid.Styles>
      <DataGrid.Columns>
        <DataGridTemplateColumn Header="Timestamp" Width="210">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:LogRowDto">
              <TextBlock Text="{Binding Timestamp}"
                          Foreground="{StaticResource Itomori.Foreground}"
                         VerticalAlignment="Center"
                         FontSize="12" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="Level" Width="72">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:LogRowDto">
              <Border CornerRadius="3" Padding="4,1" HorizontalAlignment="Left"
                       VerticalAlignment="Center">
                <TextBlock Text="{Binding Level}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Itomori.Foreground}" />
              </Border>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="Source" Width="150">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:LogRowDto">
              <TextBlock Text="{Binding Source}"
                          Foreground="{StaticResource Itomori.Foreground}"
                          VerticalAlignment="Center"
                          FontSize="12"
                          TextTrimming="CharacterEllipsis" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="Message" Width="*">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:LogRowDto">
              <TextBlock Text="{Binding Message}"
                          Foreground="{StaticResource Itomori.Foreground}"
                          VerticalAlignment="Center"
                          FontSize="12"
                          TextTrimming="CharacterEllipsis" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>

</UserControl>
