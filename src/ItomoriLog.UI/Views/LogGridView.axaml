<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ItomoriLog.UI.ViewModels"
             x:Class="ItomoriLog.UI.Views.LogGridView"
             x:DataType="vm:LogsPageViewModel">

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Filter Bar -->
    <Border Grid.Row="0" Background="{StaticResource Itomori.Panel}" Padding="12,8">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBox Watermark="Text search..."
                 Text="{Binding TextSearch}"
                 Width="200" />
        <TextBox Watermark="TICK expression (e.g. $now-1h..$now)"
                 Text="{Binding QueryText}"
                 Width="300" />
        <Button Content="↻ Refresh" Command="{Binding RefreshCommand}" />
        <TextBlock Text="{Binding StatusText}"
                   Foreground="{StaticResource Itomori.SubtleForeground}"
                   VerticalAlignment="Center" Margin="12,0,0,0" />
      </StackPanel>
    </Border>

    <!-- Log DataGrid -->
    <DataGrid Grid.Row="1"
              ItemsSource="{Binding CurrentPage}"
              SelectedItem="{Binding SelectedRow}"
              IsReadOnly="True"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              RowHeight="28"
              HeadersVisibility="Column"
              Background="{StaticResource Itomori.Background}"
              Foreground="{StaticResource Itomori.Foreground}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="220" />
        <DataGridTemplateColumn Header="Level" Width="80">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:LogRowDto">
              <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding Level}" FontSize="11" FontWeight="SemiBold" />
              </Border>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="160" />
        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- Pagination Bar -->
    <Border Grid.Row="2" Background="{StaticResource Itomori.Panel}" Padding="12,6">
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
        <Button Content="◀ Previous" Command="{Binding PreviousPageCommand}" />
        <TextBlock Text="{Binding StatusText}"
                   Foreground="{StaticResource Itomori.Foreground}"
                   VerticalAlignment="Center" />
        <Button Content="Next ▶" Command="{Binding NextPageCommand}" />
        <Button Content="Detail" Command="{Binding ToggleDetailCommand}" Margin="24,0,0,0" />
      </StackPanel>
    </Border>
  </Grid>

</UserControl>
