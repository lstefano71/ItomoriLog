<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ItomoriLog.UI.ViewModels"
             x:Class="ItomoriLog.UI.Views.FacetPanelView"
             x:DataType="vm:FacetPanelViewModel"
             MinWidth="200">

  <Border Background="{StaticResource Itomori.Panel}" Padding="12,8" CornerRadius="4">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">

        <!-- Level Facets -->
        <StackPanel Spacing="4">
          <TextBlock Text="LEVELS" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource Itomori.SubtleForeground}" Margin="0,0,0,4" />
          <ItemsControl ItemsSource="{Binding LevelFacets}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:FacetItemViewModel">
                <Button Background="Transparent" BorderThickness="0"
                        HorizontalContentAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Padding="4,3" Cursor="Hand"
                        Command="{Binding CycleStateCommand, FallbackValue={x:Null}}"
                        Name="FacetButton">
                  <Grid ColumnDefinitions="20,*,Auto">
                    <!-- State indicator -->
                    <TextBlock Grid.Column="0" FontSize="12" VerticalAlignment="Center">
                      <TextBlock.Text>
                        <Binding Path="State">
                          <Binding.Converter>
                            <vm:FacetStateToSymbolConverter />
                          </Binding.Converter>
                        </Binding>
                      </TextBlock.Text>
                    </TextBlock>
                    <!-- Level name with severity color -->
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12"
                               Foreground="{StaticResource Itomori.Foreground}"
                               VerticalAlignment="Center" />
                    <!-- Count badge -->
                    <Border Grid.Column="2" Background="#2A2F3A" CornerRadius="8" Padding="6,1">
                      <TextBlock Text="{Binding Count, StringFormat='{}{0:N0}'}" FontSize="10"
                                 Foreground="{StaticResource Itomori.SubtleForeground}"
                                 VerticalAlignment="Center" />
                    </Border>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Source Facets -->
        <StackPanel Spacing="4">
          <TextBlock Text="SOURCES" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource Itomori.SubtleForeground}" Margin="0,0,0,4" />
          <ItemsControl ItemsSource="{Binding SourceFacets}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:FacetItemViewModel">
                <Button Background="Transparent" BorderThickness="0"
                        HorizontalContentAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Padding="4,3" Cursor="Hand"
                        Command="{Binding CycleStateCommand, FallbackValue={x:Null}}"
                        Name="SourceFacetButton">
                  <Grid ColumnDefinitions="20,*,Auto">
                    <TextBlock Grid.Column="0" FontSize="12" VerticalAlignment="Center">
                      <TextBlock.Text>
                        <Binding Path="State">
                          <Binding.Converter>
                            <vm:FacetStateToSymbolConverter />
                          </Binding.Converter>
                        </Binding>
                      </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12"
                               Foreground="{StaticResource Itomori.Foreground}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <Border Grid.Column="2" Background="#2A2F3A" CornerRadius="8" Padding="6,1">
                      <TextBlock Text="{Binding Count, StringFormat='{}{0:N0}'}" FontSize="10"
                                 Foreground="{StaticResource Itomori.SubtleForeground}"
                                 VerticalAlignment="Center" />
                    </Border>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Border>

</UserControl>
