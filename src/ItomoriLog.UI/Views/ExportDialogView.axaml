<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ItomoriLog.UI.ViewModels"
             x:Class="ItomoriLog.UI.Views.ExportDialogView"
             x:DataType="vm:ExportDialogViewModel"
             IsVisible="{Binding IsOpen}">

  <!-- Dark overlay -->
  <Grid>
    <Border Background="#CC111418"
            PointerPressed="OnOverlayPressed" />

    <!-- Centered dialog panel -->
    <Border Background="#1F2430"
            CornerRadius="8"
            Width="480"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            BoxShadow="0 8 32 0 #80000000"
            Padding="24">
      <StackPanel Spacing="16">
        <!-- Title -->
        <TextBlock Text="Export Logs"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="#FF6DAE" />

        <!-- Format selector -->
        <StackPanel Spacing="4">
          <TextBlock Text="Format" FontSize="13" Foreground="#9CA3AF" />
          <StackPanel Orientation="Horizontal" Spacing="16">
            <RadioButton Content="CSV" IsChecked="{Binding IsCsv}"
                         Foreground="#D6E2F0" GroupName="Format" />
            <RadioButton Content="JSON Lines" IsChecked="{Binding IsJsonLines}"
                         Foreground="#D6E2F0" GroupName="Format" />
            <RadioButton Content="Parquet" IsChecked="{Binding IsParquet}"
                         Foreground="#D6E2F0" GroupName="Format" />
          </StackPanel>
        </StackPanel>

        <!-- File path -->
        <StackPanel Spacing="4">
          <TextBlock Text="Output file" FontSize="13" Foreground="#9CA3AF" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Text="{Binding OutputPath}"
                     Watermark="Select output file..."
                     FontSize="13" />
            <Button Grid.Column="1" Content="Browse..."
                    Command="{Binding BrowseCommand}"
                    Margin="8,0,0,0" />
          </Grid>
        </StackPanel>

        <!-- Export current filter -->
        <CheckBox Content="Export current filter only"
                  IsChecked="{Binding ExportCurrentFilter}"
                  Foreground="#D6E2F0" />

        <!-- Progress -->
        <StackPanel Spacing="4" IsVisible="{Binding IsExporting}">
          <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="6" />
          <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="#9CA3AF" />
        </StackPanel>

        <!-- Non-exporting progress text (completion) -->
        <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="#0EA5E9"
                   IsVisible="{Binding !IsExporting}" />

        <!-- Error -->
        <TextBlock Text="{Binding ErrorText}" FontSize="12" Foreground="#EF4444"
                   IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
          <Button Content="Cancel" Command="{Binding CancelCommand}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="#9CA3AF" />
          <Button Content="Export" Command="{Binding ExportCommand}"
                  Background="#FF6DAE" Foreground="#111418"
                  FontWeight="SemiBold" Padding="16,8" CornerRadius="4" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
