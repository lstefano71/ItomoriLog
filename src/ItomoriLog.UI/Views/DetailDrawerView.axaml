<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ItomoriLog.UI.ViewModels"
             x:Class="ItomoriLog.UI.Views.DetailDrawerView"
             x:DataType="vm:LogsPageViewModel"
             Width="420">

  <Border Background="{StaticResource Itomori.Panel}" Padding="16" CornerRadius="4,0,0,4">
    <Grid RowDefinitions="Auto,*">
      <!-- Header -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
        <TextBlock Text="Row Detail"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource Itomori.Foreground}" />
        <Button Content="✕" Command="{Binding ToggleDetailCommand}"
                Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Right" VerticalAlignment="Top" />
      </StackPanel>

      <ContentControl Grid.Row="1"
                      Content="{Binding SelectedRow}"
                      IsVisible="{Binding SelectedRow, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ContentControl.ContentTemplate>
          <DataTemplate x:DataType="vm:LogRowDto">
            <TabControl>
              <TabItem Header="Overview">
                <ScrollViewer>
                  <StackPanel Spacing="8" Margin="0,8">
                    <TextBlock Text="Timestamp" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" />
                    <TextBlock Text="{Binding Timestamp}"
                               Foreground="{StaticResource Itomori.Foreground}" />

                    <TextBlock Text="Level" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding Level}"
                               Foreground="{StaticResource Itomori.Foreground}" />

                    <TextBlock Text="Source" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding Source}"
                               Foreground="{StaticResource Itomori.Foreground}" />

                    <TextBlock Text="Source Path" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding SourcePath}"
                               Foreground="{StaticResource Itomori.Foreground}" TextWrapping="Wrap" />

                    <TextBlock Text="Segment ID" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding SegmentId}"
                               Foreground="{StaticResource Itomori.Foreground}" FontSize="11" />

                    <TextBlock Text="Record Index" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding RecordIndex}"
                               Foreground="{StaticResource Itomori.Foreground}" />

                    <TextBlock Text="Timestamp Basis" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding TimestampBasis}"
                               Foreground="{StaticResource Itomori.Foreground}" />

                    <TextBlock Text="Offset (minutes)" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding OffsetMinutes}"
                               Foreground="{StaticResource Itomori.Foreground}" />
                  </StackPanel>
                </ScrollViewer>
              </TabItem>

              <TabItem Header="Structured">
                <ScrollViewer>
                  <TextBlock Text="{Binding FieldsJson}"
                             Foreground="{StaticResource Itomori.Foreground}"
                             FontFamily="Cascadia Code,Consolas,monospace"
                             FontSize="12" TextWrapping="Wrap"
                             Margin="0,8" />
                </ScrollViewer>
              </TabItem>

              <TabItem Header="Raw">
                <ScrollViewer>
                  <StackPanel Spacing="4" Margin="0,8">
                    <TextBlock Text="Original Timestamp" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" />
                    <TextBlock Text="{Binding TimestampOriginal}"
                               Foreground="{StaticResource Itomori.Foreground}"
                               FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />

                    <TextBlock Text="Message" FontWeight="SemiBold"
                               Foreground="{StaticResource Itomori.SubtleForeground}" FontSize="11" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding Message}"
                               Foreground="{StaticResource Itomori.Foreground}"
                               FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </ScrollViewer>
              </TabItem>
            </TabControl>
          </DataTemplate>
        </ContentControl.ContentTemplate>
      </ContentControl>

      <!-- No selection placeholder -->
      <TextBlock Grid.Row="1" Text="Select a row to see details"
                 IsVisible="{Binding SelectedRow, Converter={x:Static ObjectConverters.IsNull}}"
                 Foreground="{StaticResource Itomori.SubtleForeground}"
                 VerticalAlignment="Center" HorizontalAlignment="Center" />
    </Grid>
  </Border>

</UserControl>
